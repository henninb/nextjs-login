# Required in production (`next start` / deployed). Use a long random value.
JWT_SECRET=

# Optional. If set, GET /api/auth/users requires Authorization: Bearer <same value>.
# Also used by scripts/list_accounts.py via ADMIN_LIST_USERS_SECRET or --token.
ADMIN_LIST_USERS_SECRET=

# Local dev only: include reset URL in forgot-password JSON (never enable in production).
# DEV_RETURN_RESET_TOKEN=1

# Optional: PerimeterX / bot script URL (https://...). Omit to load no third-party script.
# NEXT_PUBLIC_PERIMETERX_SCRIPT_URL=
